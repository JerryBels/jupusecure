# Copy to .env and fill in. .env is git-ignored.

# Required for the agent orchestrator (Phase 3+). The sandbox and the
# guardrail demo (scripts/demo_guardrails.py) run without it.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# Optional overrides (defaults shown).
GEMINI_MODEL=gemini-2.5-flash-lite
SANDBOX_IMAGE=jupus-sandbox:latest
SANDBOX_WALL_CLOCK_TIMEOUT=15
